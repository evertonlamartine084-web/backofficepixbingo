{
  "headers": [
    {
      "source": "/widget/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=60, s-maxage=60" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/widget/(.*)", "destination": "/widget/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
